# Local development database
DATABASE_URL=postgresql+psycopg://medi_check_user:medi_check_password@localhost:5432/medi_check

# App
SECRET_KEY=replace-with-a-long-random-string
JWT_SECRET_KEY=replace-with-a-long-random-string
JWT_ACCESS_SECRET_KEY=replace-with-a-long-random-string
JWT_REFRESH_SECRET_KEY=replace-with-a-long-random-string
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30
SQL_ECHO=false

# CORS
CORS_ORIGINS=http://localhost:8081,http://127.0.0.1:8081
ENVIRONMENT=development
